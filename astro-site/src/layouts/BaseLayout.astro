---
import '../styles/global.css';

const siteUrl = 'https://cristian-cordero.dev';
const {
  title = 'Cristian Cordero',
  description = 'A network automation, Python, and engineering focused blog.',
  canonicalPath = Astro.url.pathname,
  type = 'website',
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const pageTitle = title === 'Cristian Cordero' ? title : `${title} | Cristian Cordero`;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (() => {
        const storageKey = 'site-theme';
        const root = document.documentElement;

        try {
          const savedTheme = localStorage.getItem(storageKey);
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          root.dataset.theme = savedTheme || systemTheme;
        } catch {
          root.dataset.theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/avatar.jpg`} />
    <meta name="twitter:card" content="summary" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Cristian Cordero" href="/rss.xml" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <div class="header-bar">
        <a class="brand" href="/" aria-label="Cristian Cordero home">
          <span class="brand-mark" aria-hidden="true">~/</span>
          <span>Cristian Cordero</span>
        </a>
        <div class="header-actions">
          <nav aria-label="Primary navigation">
            <a href="/blog/">Blog</a>
            <a href="/tags/">Tags</a>
            <a href="/#experience">Experience</a>
            <a href="/#contact">Contact</a>
          </nav>
          <button class="theme-toggle" type="button" aria-label="Switch to dark theme" aria-pressed="false">
            <span class="theme-toggle-icon" aria-hidden="true">L</span>
            <span class="theme-toggle-text">Light</span>
          </button>
        </div>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <p><span aria-hidden="true">::</span> Network automation, Kubernetes, telemetry, and cloud-native infrastructure.</p>
      <p><a href="/rss.xml">RSS feed</a></p>
    </footer>
    <script is:inline>
      (() => {
        const storageKey = 'site-theme';
        const root = document.documentElement;
        const toggle = document.querySelector('.theme-toggle');

        if (!toggle) return;

        const updateToggle = () => {
          const isDark = root.dataset.theme === 'dark';
          toggle.setAttribute('aria-pressed', String(isDark));
          toggle.setAttribute('aria-label', `Switch to ${isDark ? 'light' : 'dark'} theme`);
          const icon = toggle.querySelector('.theme-toggle-icon');
          const text = toggle.querySelector('.theme-toggle-text');
          if (icon) icon.textContent = isDark ? 'D' : 'L';
          if (text) text.textContent = isDark ? 'Dark' : 'Light';
        };

        updateToggle();

        toggle.addEventListener('click', () => {
          const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
          root.dataset.theme = nextTheme;
          try {
            localStorage.setItem(storageKey, nextTheme);
          } catch {
            // Theme persistence is optional when storage is unavailable.
          }
          updateToggle();
        });
      })();
    </script>
  </body>
</html>
