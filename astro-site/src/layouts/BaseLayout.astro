---
import '../styles/global.css';

const siteUrl = 'https://cristian-cordero.dev';
const {
  title = 'Cristian Cordero',
  description = 'A network automation, Python, and engineering focused blog.',
  canonicalPath = Astro.url.pathname,
  type = 'website',
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const pageTitle = title === 'Cristian Cordero' ? title : `${title} | Cristian Cordero`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/avatar.jpg`} />
    <meta name="twitter:card" content="summary" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Cristian Cordero" href="/rss.xml" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Cristian Cordero</a>
      <nav aria-label="Primary navigation">
        <a href="/blog/">Blog</a>
        <a href="/#experience">Experience</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Network automation, Kubernetes, telemetry, and cloud-native infrastructure.</p>
      <p><a href="/rss.xml">RSS</a></p>
    </footer>
  </body>
</html>
